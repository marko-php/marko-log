{
    "name": "marko/log",
    "description": "PSR-3 compatible logging interfaces and formatters for Marko Framework",
    "license": "MIT",
    "type": "marko-module",
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        },
        {
            "type": "path",
            "url": "../config"
        }
    ],
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/config": "@dev"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Log\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Log\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
